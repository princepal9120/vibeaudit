// Prisma schema for VibeAudit
// Uses better-auth for authentication

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// better-auth models (required field names)
// ==========================================

model user {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      session[]
  accounts      account[]

  // VibeAudit relations
  scans         Scan[]
  reports       Report[]

  @@index([email])
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ==========================================
// VibeAudit models
// ==========================================

model Scan {
  id              String    @id @default(cuid())
  userId          String
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  githubRepoUrl   String?
  liveUrl         String?
  branch          String?   @default("main")

  status          ScanStatus @default(QUEUED)
  progress        String?    // "Scanning repo...", "Running DAST...", etc
  progressPercent Int?       @default(0)
  errorMessage    String?

  // Scan metadata
  totalFindings   Int?
  criticalCount   Int?
  highCount       Int?
  mediumCount     Int?
  lowCount        Int?

  report          Report?

  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ScanStatus {
  QUEUED
  CLONING
  SCANNING
  ANALYZING
  GENERATING_REPORT
  COMPLETED
  FAILED
  CANCELLED
}

model Report {
  id              String    @id @default(cuid())
  scanId          String    @unique
  scan            Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  userId          String
  user            user      @relation(fields: [userId], references: [id])

  securityScore   Int       // 0-100

  // Summary stats
  totalFindings   Int       @default(0)
  criticalCount   Int       @default(0)
  highCount       Int       @default(0)
  mediumCount     Int       @default(0)
  lowCount        Int       @default(0)

  // Generated content
  executiveSummary String?  @db.Text
  pdfUrl          String?   // S3 URL

  // Sharing
  shareToken      String?   @unique
  shareExpiresAt  DateTime?

  findings        Finding[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([shareToken])
}

model Finding {
  id              String    @id @default(cuid())
  reportId        String
  report          Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Core finding data
  title           String    // "SQL Injection", "Hardcoded API Key"
  severity        Severity
  category        FindingCategory
  source          ScanSource // "semgrep", "zap", "npm-audit", "trivy", "gitleaks"

  // AI-enhanced explanations
  description     String    @db.Text // "What it is"
  impact          String    @db.Text // "Why it matters"
  remediation     String    @db.Text // "How to fix"

  // Code context
  filePath        String?
  lineNumber      Int?
  codeSnippet     String?   @db.Text

  // Confidence and validation
  confidence      Float     @default(1.0)
  aiValidated     Boolean   @default(false)
  falsePositive   Boolean   @default(false)

  // Original tool output
  rawFinding      Json      // Original finding from tool
  ruleId          String?   // Tool-specific rule identifier

  createdAt       DateTime  @default(now())

  @@index([reportId])
  @@index([severity])
  @@index([category])
  @@index([source])
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum FindingCategory {
  INJECTION
  SECRETS
  AUTH
  HEADERS
  XSS
  CSRF
  DEPENDENCIES
  CRYPTOGRAPHY
  CONFIGURATION
  OTHER
}

enum ScanSource {
  SEMGREP
  ZAP
  NPM_AUDIT
  TRIVY
  GITLEAKS
}

// Payment tracking (for pay-per-scan model)
model Payment {
  id              String    @id @default(cuid())
  userId          String
  scanId          String?

  amount          Int       // Amount in cents
  currency        String    @default("usd")
  status          PaymentStatus @default(PENDING)

  stripePaymentId String?   @unique
  stripeSessionId String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([stripePaymentId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
