
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model user {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 2FA fields
  twoFactorEnabled Boolean @default(false)

  // Organization fields
  activeOrganizationId String?

  sessions      session[]
  accounts      account[]

  scans         Scan[]
  reports       Report[]
  payments      Payment[]
  scanCredit    ScanCredit?

  // PRD Review feature
  subscription  Subscription?
  prdUsage      PrdUsage[]
  prdReviews    PrdReview[]

  // Organization relations
  members       member[]
  invitations   invitation[]
  twoFactor     twoFactor?

  @@index([email])
}

model session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Organization context
  activeOrganizationId String?

  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}


model Scan {
  id              String    @id @default(cuid())
  userId          String
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  githubRepoUrl   String?
  liveUrl         String?
  branch          String?   @default("main")

  status          ScanStatus @default(QUEUED)
  progress        String?    // "Scanning repo...", "Running DAST...", etc
  progressPercent Int?       @default(0)
  errorMessage    String?

  // Scan metadata
  totalFindings   Int?
  criticalCount   Int?
  highCount       Int?
  mediumCount     Int?
  lowCount        Int?

  report          Report?

  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum ScanStatus {
  QUEUED
  CLONING
  SCANNING
  ANALYZING
  GENERATING_REPORT
  COMPLETED
  FAILED
  CANCELLED
}

model Report {
  id              String    @id @default(cuid())
  scanId          String    @unique
  scan            Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  userId          String
  user            user      @relation(fields: [userId], references: [id])

  securityScore   Int       // 0-100

  // Summary stats
  totalFindings   Int       @default(0)
  criticalCount   Int       @default(0)
  highCount       Int       @default(0)
  mediumCount     Int       @default(0)
  lowCount        Int       @default(0)

  // Generated content
  executiveSummary String?  @db.Text
  pdfUrl          String?   // ImageKit URL
  pdfFileId       String?   // ImageKit file ID

  // Sharing
  shareToken      String?   @unique
  shareExpiresAt  DateTime?

  findings        Finding[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([shareToken])
}

model Finding {
  id              String    @id @default(cuid())
  reportId        String
  report          Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  // Core finding data
  title           String    // "SQL Injection", "Hardcoded API Key"
  severity        Severity
  category        FindingCategory
  source          ScanSource // "semgrep", "zap", "npm-audit", "trivy", "gitleaks"

  // AI-enhanced explanations
  description     String    @db.Text // "What it is"
  impact          String    @db.Text // "Why it matters"
  remediation     String    @db.Text // "How to fix"

  // Code context
  filePath        String?
  lineNumber      Int?
  codeSnippet     String?   @db.Text

  // Confidence and validation
  confidence      Float     @default(1.0)
  aiValidated     Boolean   @default(false)
  falsePositive   Boolean   @default(false)

  // Original tool output
  rawFinding      Json      // Original finding from tool
  ruleId          String?   // Tool-specific rule identifier

  createdAt       DateTime  @default(now())

  @@index([reportId])
  @@index([severity])
  @@index([category])
  @@index([source])
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum FindingCategory {
  INJECTION
  SECRETS
  AUTH
  HEADERS
  XSS
  CSRF
  DEPENDENCIES
  CRYPTOGRAPHY
  CONFIGURATION
  RACE_CONDITION
  IDOR
  SSRF
  MASS_ASSIGNMENT
  DESERIALIZATION
  // Launch readiness categories
  SEO
  PERFORMANCE
  ACCESSIBILITY
  ESSENTIALS
  OTHER
}

enum ScanSource {
  SEMGREP
  ZAP
  NPM_AUDIT
  TRIVY
  GITLEAKS
  ADVANCED
  // Launch readiness scanners
  SEO_SCANNER
  PERFORMANCE_SCANNER
  ACCESSIBILITY_SCANNER
  ESSENTIALS_SCANNER
}

// Payment tracking (for pay-per-scan model)
model Payment {
  id              String    @id @default(cuid())
  userId          String
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Dodo Payments fields
  dodoPaymentId   String?   @unique
  dodoSessionId   String?   @unique
  dodoCustomerId  String?

  // Payment details
  amount          Int       // Amount in cents
  currency        String    @default("USD")
  status          PaymentStatus @default(PENDING)

  // Product info
  productType     ProductType   @default(SCAN_CREDIT)
  quantity        Int           @default(1)

  // Metadata
  metadata        Json?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  @@index([userId])
  @@index([dodoPaymentId])
  @@index([status])
}

// Track user scan credits
model ScanCredit {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalCredits    Int       @default(1)  // Start with 1 free scan
  usedCredits     Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

enum ProductType {
  SCAN_CREDIT      // Single scan ($39)
  SCAN_BUNDLE_5    // 5-pack ($99)
  SCAN_BUNDLE_10   // 10-pack ($179)
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// PRD Review feature
enum SubscriptionPlan {
  FREE  // 2 reviews/month
  PRO   // Unlimited reviews
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum PrdReviewStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               user               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  dodoSubscriptionId String?            @unique
  dodoCustomerId     String?
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([userId])
}

model PrdUsage {
  id           String   @id @default(cuid())
  userId       String
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart  DateTime
  periodEnd    DateTime
  reviewsUsed  Int      @default(0)
  reviewsLimit Int      @default(2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, periodStart])
  @@index([userId])
}

model PrdReview {
  id               String          @id @default(cuid())
  userId           String
  user             user            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  originalContent  String          @db.Text
  fileName         String?
  status           PrdReviewStatus @default(PENDING)
  errorMessage     String?
  securedContent   String?         @db.Text
  securityScore    Int?
  findings         Json?
  frameworkCoverage Json?
  processingTimeMs Int?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?

  // PDF Storage (ImageKit)
  pdfUrl           String?
  pdfFileId        String?

  // Sharing
  shareToken       String?         @unique
  shareExpiresAt   DateTime?

  @@index([userId])
  @@index([status])
  @@index([shareToken])
}

// ============================================
// Organization Plugin Models (Better Auth)
// ============================================

model organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     member[]
  invitations invitation[]

  @@index([slug])
}

model member {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           String   @default("member") // owner, admin, member
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         user         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model invitation {
  id             String   @id @default(cuid())
  organizationId String
  email          String
  role           String   @default("member")
  status         String   @default("pending") // pending, accepted, expired
  inviterId      String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      user         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
}

// ============================================
// Two-Factor Authentication Model (Better Auth)
// ============================================

model twoFactor {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  backupCodes String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
