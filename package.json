{
  "name": "vibeaudit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "dev:mcp": "npm run dev -w @vibeaudit/mcp-server",
    "build": "npm run build -w apps/web && npm run build -w apps/api && npm run build:mcp",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "build:mcp": "npm run build -w @vibeaudit/mcp-server",
    "start": "concurrently \"npm run start:api\" \"npm run start:web\"",
    "start:web": "npm run start -w apps/web",
    "start:api": "npm run start -w apps/api",
    "start:mcp": "npm run start -w @vibeaudit/mcp-server",
    "mcp:inspect": "npm run inspect -w @vibeaudit/mcp-server",
    "lint": "npm run lint -w apps/web",
    "db:generate": "npm run db:generate -w apps/api",
    "db:push": "npm run db:push -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:studio": "npm run db:studio -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5"
  }
}
