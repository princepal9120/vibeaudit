{
  "name": "ShipSafe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "dev:web": "pnpm run dev --filter @ShipSafe/web",
    "dev:api": "pnpm run dev --filter @ShipSafe/api",
    "dev:mcp": "pnpm run dev --filter @ShipSafe/mcp-server",
    "build": "pnpm run build --filter @ShipSafe/web && pnpm run build --filter @ShipSafe/api && pnpm run build:mcp",
    "build:web": "pnpm run build --filter @ShipSafe/web",
    "build:api": "pnpm run build --filter @ShipSafe/api",
    "build:mcp": "pnpm run build --filter @ShipSafe/mcp-server",
    "start": "concurrently \"pnpm run start:api\" \"pnpm run start:web\"",
    "start:web": "pnpm run start --filter @ShipSafe/web",
    "start:api": "pnpm run start --filter @ShipSafe/api",
    "start:mcp": "pnpm run start --filter @ShipSafe/mcp-server",
    "mcp:inspect": "pnpm run inspect --filter @ShipSafe/mcp-server",
    "lint": "pnpm run lint --filter @ShipSafe/web",
    "db:generate": "pnpm --filter @ShipSafe/api exec prisma generate",
    "db:push": "pnpm --filter @ShipSafe/api exec prisma db push",
    "db:migrate": "pnpm --filter @ShipSafe/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @ShipSafe/api exec prisma studio"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5"
  }
}